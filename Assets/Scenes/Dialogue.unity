  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7664c39ea14ad9346aa6bda7bcb78497, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::Dialogue
  dialogueMark: {fileID: 337570573}
  dialoguePanel: {fileID: 979685755}
  dialogueText: {fileID: 333294644}
  dialogueLines:
  - "ANNIE: (To alegre) Quina alegria! La Misery \xE9s viva! No s\xE9 si hagu\xE9s
    pogut passar un  dia m\xE9s pensant en qu\xE8 s\u2019havia fet d\u2019ella\u2026
    \xC9s el millor dia de la meva vida! I ara qu\xE8? S\u2019enamorar\xE0 perdudament
    d\u2019un majestu\xF3s home o seguir\xE0 amb la seva vida aventuresca? \r\n"
  - "ANNIE: Ai quina intriga! No puc esperar per seguir llegint!  \n(To amena\xE7ant)
    Espero que la resta de la historia estigui a l\u2019al\xE7ada o hi haur\xE0 greus
    conseq\xFC\xE8ncies."
  - "PAUL: Sabia que t\u2019encantaria\u2026 per\xF2 haur\xE0s d\u2019esperar una
    mica per saber com segueix. Ja saps que els bons autors han de rumiar prou per
    escriure com cal. L\u2019espera valdr\xE0 la pena, t\u2019ho prometo.\r\n"
  moveSpeed: 3
  target: {fileID: 1768601734}
  levelexit: {fileID: 1398247264}
